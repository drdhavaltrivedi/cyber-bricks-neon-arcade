{
  "manifest_version": 3,
  "name": "Cyber-Bricks: Neon Arcade",
  "version": "1.0.0",
  "description": "Retro-synthwave brick breaker arcade game with rich visuals and synthesized sound. Play from your toolbar or in full screen!",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cyber-bricks@brilworks.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
